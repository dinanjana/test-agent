# MongoDB connection string
MONGO_URI=mongodb://localhost:27017/testagent

# Redis connection string (required for task queuing in future phases)
REDIS_URL=redis://localhost:6379

# API server port
PORT=3001

# LLM API keys (stored per-app in settings; these are optional fallbacks)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=...

# Encryption key for secrets at rest (required before production deployment)
# SECRETS_ENCRYPTION_KEY=32-byte-hex-key-here
