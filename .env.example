# Copy to .env (docker compose reads it automatically): cp .env.example .env
#
# OpenAI API key. Required by the bundled mock-agent to generate sample responses.
# Optional for the API itself — LLM provider keys are normally set per app in the
# Settings UI (BYOK). If you serve the web UI from a host other than localhost,
# rebuild the web image with --build-arg NEXT_PUBLIC_API_URL=https://your-host:3001
OPENAI_API_KEY=
